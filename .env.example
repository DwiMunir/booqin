# Wajib (default localhost saat dev/build).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_ENV=development

# Diaktifkan & diperketat di fasenya masing-masing (Fase 2 = Sanity, Fase 3 = Resend).
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_API_TOKEN=
CMS_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
# Pengirim email konfirmasi — domain HARUS terverifikasi di Resend (SPF/DKIM/DMARC).
RESEND_FROM=Booqin <hello@booqin.moonir.dev>

# Anti-spam: honeypot + time-check + rate limit per-IP IN-MEMORY (single-instance, tanpa env).

# Monitoring (opsional). Isi SENTRY_DSN untuk aktifkan error tracking server-side.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
